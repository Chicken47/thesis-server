# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Neon Postgres (same DB as frontend)
DATABASE_URL=postgresql://...

# Flask
FLASK_DEBUG=false
PORT=5000

# CORS — comma-separated, set to your Vercel frontend URL
ALLOWED_ORIGINS=https://your-app.vercel.app

# Stock cache dir (defaults to ./stock_cache if unset)
# STOCK_CACHE_DIR=/tmp/stock_cache
